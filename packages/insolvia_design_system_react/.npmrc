# @insolvia is published to GitHub Packages, not npmjs.org. Everything else
# (react, tailwind, base-ui, …) still resolves from the public registry.
@insolvia:registry=https://npm.pkg.github.com

# npm expands ${NODE_AUTH_TOKEN} from the environment when it READS this file.
# The variable reference below is the literal, committed content — this repo is
# public (see CLAUDE.md), so a real token must never appear here. CI supplies
# the value via `NODE_AUTH_TOKEN: ${{ secrets.GITHUB_TOKEN }}`; a human running
# `npm install @insolvia/...` exports their own PAT with `read:packages`.
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
