# @insolvia-ai is published to GitHub Packages, not npmjs.org. Everything else
# (react, react-router, tailwind, …) still resolves from the public registry.
@insolvia-ai:registry=https://npm.pkg.github.com

# npm expands ${NODE_AUTH_TOKEN} from the environment when it READS this file.
# The variable reference below is the literal, committed content — this repo is
# public (see CLAUDE.md), so a real token must never appear here. CI supplies
# the value via `NODE_AUTH_TOKEN: ${{ secrets.GITHUB_TOKEN }}`; a human runs
#   export NODE_AUTH_TOKEN="$(gh auth token)"   # needs read:packages
# before `npm install`. GitHub Packages requires a token even for public
# packages, so an unset NODE_AUTH_TOKEN fails the install with a 401.
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
